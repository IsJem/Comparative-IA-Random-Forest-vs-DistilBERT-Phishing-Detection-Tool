{
  "manifest_version": 3,
  "name": "Phishing Detector - RF vs DB",
  "version": "2.0",
  "description": "Comparativa entre Random Forest y DistilBERT para detección de phishing",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5001/*",
    "http://localhost:5001/*"
  ],
  "icons": {
    "128": "IA.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "🔍 Phishing Detector",
    "default_icon": "IA.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["comparator.html"],
      "matches": ["<all_urls>"]
    }
  ]
}